# gemini MCP サーバーの設定例。コピーして使う:  cp .env.example .env
# （.env は .gitignore 済み。実キーはコミットしないこと）

# バックエンド: mock | api | ollama
GEMINI_BACKEND=api

# --- api バックエンド用 ---
# https://aistudio.google.com/apikey で取得
GEMINI_API_KEY=your-key-here
GEMINI_MODEL=gemini-2.5-flash

# --- ollama バックエンド用（完全ローカル） ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gemma3
